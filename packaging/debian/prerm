#!/bin/sh
set -e

INSTALL_ROOT="/opt/telegram-uploader"
ENV_FILE="/etc/telegram-uploader/.env"
COMPOSE_FILE="${INSTALL_ROOT}/docker-compose.yml"

if command -v docker >/dev/null 2>&1 && [ -f "$COMPOSE_FILE" ] && [ -f "$ENV_FILE" ]; then
  TELEGRAM_UPLOADER_ENV_FILE="$ENV_FILE" \
    docker compose -f "$COMPOSE_FILE" down 2>/dev/null || true
fi

exit 0
