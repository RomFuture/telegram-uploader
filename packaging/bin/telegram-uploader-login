#!/usr/bin/env bash
# Client API one-time login for packaged install (phone + code via Telethon).
set -euo pipefail

INSTALL_ROOT="/opt/telegram-uploader"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/env-path.sh"

VENV_PYTHON="${INSTALL_ROOT}/.venv/bin/python"

case "${1:-}" in
  --help|-h)
    echo "Usage: telegram-uploader-login [--no-intro]"
    echo "  One-time Telegram sign-in (phone + code). Run after Settings → Save."
    exit 0
    ;;
esac

ENV_FILE="$(resolve_env_file)" || {
  echo "error: no config. Run: telegram-uploader --setup" >&2
  echo "Then open Settings, fill Client API fields, click Save." >&2
  exit 1
}

load_env_file "$ENV_FILE"
export TELEGRAM_UPLOADER_ENV_FILE="$ENV_FILE"

if [[ ! -x "$VENV_PYTHON" ]]; then
  echo "error: ${VENV_PYTHON} not found — reinstall telegram-uploader package." >&2
  exit 1
fi

exec "$VENV_PYTHON" -m application.telegram_login_cli "$@"
