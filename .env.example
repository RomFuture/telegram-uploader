# App
APP_ENV=development
APP_LOG_LEVEL=INFO

# Database (match docker-compose; use 5433 if system postgres already uses 5432)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=telegram_uploader
POSTGRES_USER=telegram_uploader
POSTGRES_PASSWORD=telegram_uploader

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Telegram: Client API (default — your user account, not a bot) ─────────────
# See docs/CLIENT_API_SETUP.md
#
# Your account is NOT stored as login/password in .env.
# 1. Fill API_ID + API_HASH from https://my.telegram.org
# 2. Set TARGET_CHAT_ID (backup group)
# 3. Sign in once: Settings → Client API → Sign in to Telegram…
#    (or: telegram-uploader-login in a terminal)
#    → saves session to TELEGRAM_SESSION_PATH
TELEGRAM_PROVIDER=client
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Host directory mounted into Docker workers at /data/telegram
TELEGRAM_SESSION_DIR=${HOME}/.config/telegram-uploader
TELEGRAM_SESSION_PATH=${HOME}/.config/telegram-uploader/session.session
TELEGRAM_TARGET_CHAT_ID=

# ── Telegram: Bot API (optional — only if TELEGRAM_PROVIDER=bot) ────────────
# Leave empty when using client. Bot token is NOT your personal account.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_URL=http://localhost:8081

# Security
ARCHIVE_ENCRYPTION_KEY=change_me_or_leave_empty_for_auto

# Host path mounted read-only into workers (default: $HOME). Packaged install also
# mounts INSTALL_ROOT (/opt/telegram-uploader) via docker-compose.
HOST_SOURCE_MOUNT=

# Archive cache on host GUI; workers use shared docker volume /data/archive-cache
ARCHIVE_CACHE_DIR=${HOME}/.config/telegram-uploader/cache
