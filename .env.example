# App
APP_ENV=development
APP_LOG_LEVEL=INFO

# Database (match docker-compose; use 5433 if system postgres already uses 5432)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=telegram_uploader
POSTGRES_USER=telegram_uploader
POSTGRES_PASSWORD=telegram_uploader

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Telegram (v1 provider) — see docs/TELEGRAM_SETUP.md
# TELEGRAM_API_ID is numeric from https://my.telegram.org (not the bot token)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_URL=http://localhost:8081
TELEGRAM_TARGET_CHAT_ID=

# Security
ARCHIVE_ENCRYPTION_KEY=change_me_or_leave_empty_for_auto

# Host path mounted read-only into workers at the same path (default: $HOME)
# Files to back up must live under this tree when using docker workers.
HOST_SOURCE_MOUNT=

# Archive cache on host GUI; workers use shared docker volume /data/archive-cache
ARCHIVE_CACHE_DIR=/tmp/telegram_uploader
