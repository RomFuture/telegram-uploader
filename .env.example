# App
APP_ENV=development
APP_LOG_LEVEL=INFO

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=telegram_uploader
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Telegram (v1 provider)
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_BOT_API_URL=http://localhost:8081
TELEGRAM_TARGET_CHAT_ID=change_me
TELEGRAM_API_ID=change_me
TELEGRAM_API_HASH=change_me

# Security
ARCHIVE_ENCRYPTION_KEY=change_me_or_leave_empty_for_auto

# Archive cache (temporary volumes before upload)
ARCHIVE_CACHE_DIR=/tmp/telegram_uploader
